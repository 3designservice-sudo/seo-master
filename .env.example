# ===================================
# SEO Master Bot v2 — Environment Variables
# Copy to .env and fill in your values
# ===================================

# === Required ===
TELEGRAM_BOT_TOKEN=           # Token from @BotFather
ADMIN_IDS=                    # Telegram IDs of admins, comma-separated (GOD MODE)
SUPABASE_URL=                 # https://xxx.supabase.co
SUPABASE_KEY=                 # service_role key (server-side, NOT anon)
UPSTASH_REDIS_URL=            # https://xxx.upstash.io (HTTP endpoint)
UPSTASH_REDIS_TOKEN=          # Upstash Redis REST token
QSTASH_TOKEN=                 # QStash token for scheduling
QSTASH_CURRENT_SIGNING_KEY=   # QStash webhook verification
QSTASH_NEXT_SIGNING_KEY=      # QStash rotated key
OPENROUTER_API_KEY=           # OpenRouter key (all AI models)
FIRECRAWL_API_KEY=            # Firecrawl API key
ENCRYPTION_KEY=               # Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TELEGRAM_WEBHOOK_SECRET=      # python -c "import secrets; print(secrets.token_hex(32))"

# === Optional ===
DATAFORSEO_LOGIN=             # DataForSEO login
DATAFORSEO_PASSWORD=          # DataForSEO password
SERPER_API_KEY=               # Serper.dev API key
YOOKASSA_SHOP_ID=             # YooKassa shop ID
YOOKASSA_SECRET_KEY=          # YooKassa secret key
SENTRY_DSN=                   # Sentry DSN for error monitoring
RAILWAY_PUBLIC_URL=           # Public URL on Railway (for webhooks)
PINTEREST_APP_ID=             # Pinterest App ID (OAuth)
PINTEREST_APP_SECRET=         # Pinterest App Secret
HEALTH_CHECK_TOKEN=           # Bearer token for detailed health: python -c "import secrets; print(secrets.token_hex(32))"
USD_RUB_RATE=92.5             # USD to RUB rate for admin cost display

# --- Bamboodom.ru blog API (admin-only section) ---
BAMBOODOM_BLOG_KEY=            # X-Blog-Key for https://bamboodom.ru/api.php (admin section only)
BAMBOODOM_API_BASE=https://bamboodom.ru/api.php
BAMBOODOM_ENABLED=0            # Set to 1 to show Bamboodom section in admin panel

# === Defaults (override if needed) ===
# DEFAULT_TIMEZONE=Europe/Moscow
# FSM_TTL_SECONDS=86400
# FSM_INACTIVITY_TIMEOUT=1800
# PREVIEW_TTL_SECONDS=86400
# MAX_REGENERATIONS_FREE=2
# RAILWAY_GRACEFUL_SHUTDOWN_TIMEOUT=120

# --- Yandex Webmaster (Bamboodom recrawl, 4D) ---
YANDEX_WEBMASTER_TOKEN=        # OAuth-token c webmaster:hosts scope
YANDEX_WEBMASTER_USER_ID=      # optional - resolved automatically
YANDEX_WEBMASTER_HOST_ID=      # optional - resolved automatically
YANDEX_WEBMASTER_SITE=https://bamboodom.ru

# --- Designservice.group blog (admin-only section, 2026-05-19) ---
# Set DESIGNSERVICE_ENABLED=1 to show Designservice.group section in admin panel.
DESIGNSERVICE_ENABLED=0
DESIGNSERVICE_BASE_URL=https://designservice.group
DESIGNSERVICE_RECEIVER_KEY=            # X-Receiver-Key for _receiver.php (POST base64 → file)
DESIGNSERVICE_BOT_API_KEY=             # Key for _bot_api.php (get_planned / mark_status)
DESIGNSERVICE_IMAGES_ENABLED=0         # 1 = generate cover images via OpenRouter Gemini
DESIGNSERVICE_TG_CHANNEL=              # @channel for blog announcements (optional)
DESIGNSERVICE_TG_BOT_TOKEN=            # Dedicated bot for the channel (optional)
DESIGNSERVICE_ANNOUNCE_PROJECT_ID=0    # projects.id for VK/Pinterest/Telegram announce flow

# --- Yandex Webmaster (Designservice recrawl) ---
YANDEX_WEBMASTER_TOKEN_DS=             # OAuth-token c webmaster:hosts scope (может совпадать с YANDEX_WEBMASTER_TOKEN)
YANDEX_WEBMASTER_USER_ID_DS=           # optional - resolved automatically
YANDEX_WEBMASTER_HOST_ID_DS=           # optional - resolved automatically
YANDEX_WEBMASTER_SITE_DS=https://designservice.group
